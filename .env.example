# 凭证（按优先级使用）
# A. 推荐：邮箱 + 密码（首次登录后自动持久化 refresh_token，长期可用）
ELEVENLABS_EMAIL=
ELEVENLABS_PASSWORD=

# B. 引导：从浏览器 IndexedDB 拷一次 refresh_token（之后可清空，长期由 .auth.json 持有）
#    取法：登录 elevenlabs.io 后在 DevTools Console 执行
#      indexedDB.open("firebaseLocalStorageDb").onsuccess = e => {
#        const db = e.target.result;
#        db.transaction("firebaseLocalStorage").objectStore("firebaseLocalStorage").getAll()
#          .onsuccess = ev => ev.target.result
#            .filter(x => x.fbase_key?.startsWith("firebase:authUser:"))
#            .forEach(x => console.log(x.value.stsTokenManager.refreshToken));
#      };
ELEVENLABS_REFRESH_TOKEN=

# C. 兜底：从浏览器 DevTools → 任一 api.us.elevenlabs.io 的 Authorization 头复制
#    无续期，~1 小时后失效
ELEVENLABS_BEARER_TOKEN=

# Firebase API key（留空：启动时从 https://elevenlabs.io 主页自动发现）
FIREBASE_API_KEY=
# 以下默认值与 elevenlabs.io 当前 Web 应用一致，一般不用改
# FIREBASE_GMPID=1:265222077342:web:3acce90d1596672570348f
# FIREBASE_CLIENT_VERSION=Chrome/JsCore/11.2.0/FirebaseCore-web
# FIREBASE_CLIENT_DATA=CKmdygEIlfLKAQiSocsBCIWgzQE=

# token 状态持久化文件（含 refresh_token，已写入 .gitignore）
TOKEN_STATE_PATH=.auth.json
# 提前 N 秒续期
REFRESH_SAFETY_SECONDS=300

# 上游
ELEVENLABS_BASE_URL=https://api.us.elevenlabs.io
ELEVENLABS_ORIGIN=https://elevenlabs.io

# 出站代理（强制；启动期会校验）
PROXY_URL=socks5://127.0.0.1:7899
EXPECTED_EGRESS_IP=38.15.30.162

# 浏览器指纹
IMPERSONATE=chrome131
ACCEPT_LANGUAGE=en-US,en;q=0.9

# TTS 默认值
DEFAULT_MODEL_ID=eleven_v3
DEFAULT_VOICE_ID=FzF9ACIefsb6wbrYVjf1
DEFAULT_STABILITY=0.5

# 服务监听
HOST=127.0.0.1
PORT=8000
