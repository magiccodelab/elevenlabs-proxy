# ElevenLabs Web Bearer (Firebase ID token, ~1h expiry)
# 从浏览器 DevTools → 任一 api.us.elevenlabs.io 请求的 Authorization 头复制
ELEVENLABS_BEARER_TOKEN=

# 上游
ELEVENLABS_BASE_URL=https://api.us.elevenlabs.io
ELEVENLABS_ORIGIN=https://elevenlabs.io

# 出站代理（强制；启动期会校验）
PROXY_URL=socks5://127.0.0.1:7899
EXPECTED_EGRESS_IP=38.15.30.162

# 浏览器指纹
IMPERSONATE=chrome131
ACCEPT_LANGUAGE=en-US,en;q=0.9

# TTS 默认值
DEFAULT_MODEL_ID=eleven_v3
DEFAULT_VOICE_ID=FzF9ACIefsb6wbrYVjf1
DEFAULT_STABILITY=0.5

# 服务监听
HOST=127.0.0.1
PORT=8000
